# ETAIQ Environment Configuration
# Copy this file to .env and fill in your values

# PostgreSQL connection string
DATABASE_URL=postgresql://etaiq:etaiq@localhost:5432/etaiq

# JWT signing secret for authentication
JWT_SECRET=your-secure-jwt-secret-here

# OpenAI API key for AI assistant features
OPENAI_API_KEY=sk-your-openai-api-key

# Google Gemini API key for alternative AI provider
GEMINI_API_KEY=your-gemini-api-key

# Path to trained ML model artifacts
MODEL_PATH=./ml/artifacts

# Logging verbosity (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Backend settings
ENVIRONMENT=development
DEBUG=false
API_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000

# Frontend settings
NEXT_PUBLIC_API_URL=http://localhost:8000

# ETAIQ Environment Configuration
# Copy this file to .env and fill in your values
#
# BACKEND: see backend/.env.example for the canonical backend env template.
# ROOT .env is used by docker-compose (injected into containers).

# --- OpenRouter (AI Assistant) ---
# Required for the AI assistant to function.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-chat-v3
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Security ---
JWT_SECRET=change-me-to-a-random-secret

# --- Database (optional for local dev) ---
DATABASE_URL=postgresql://etaiq:etaiq@localhost:5432/etaiq

# --- ML Model Artifacts ---
MODEL_PATH=./ml/artifacts

# --- Logging ---
LOG_LEVEL=INFO

# --- Backend settings ---
ENVIRONMENT=development
DEBUG=false
API_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000

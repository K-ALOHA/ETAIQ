# =============================================================================
# ETAIQ Backend Environment Variables — CANONICAL BACKEND CONFIG
# Copy this file to .env and fill in your values.
#
# This file is the single source of truth for backend configuration.
# - Running `make backend` (or `uvicorn` from backend/): pydantic-settings loads
#   this file automatically (env_file=".env").
# - Running via Docker Compose: docker-compose.yml injects ../backend/.env
#   into the backend container (same file). Root .env is used for frontend.
# =============================================================================

# --- OpenRouter (AI Assistant) ---
# Required: the AI assistant endpoint will fail without an API key.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-chat-v3
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Security ---
# REQUIRED for production-like environments. Change to a strong random value.
JWT_SECRET=change-me-to-a-random-secret

# --- Database (optional for local dev) ---
DATABASE_URL=

# --- ML Model Artifacts ---
MODEL_PATH=./ml/artifacts

# --- Logging ---
LOG_LEVEL=INFO

# --- Backend runtime ---
ENVIRONMENT=development
DEBUG=false
API_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000
